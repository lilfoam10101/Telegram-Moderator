# Moderator bot (Pledge Mod) — runs npm start
BOT_TOKEN=your_moderator_bot_token_from_botfather

# Notify bot — GitHub Actions deploy notifications (separate bot)
NOTIFY_BOT_TOKEN=your_notify_bot_token_from_botfather

# Optional: group IDs for DM admin check (required on Railway when data/ is empty)
KNOWN_CHAT_IDS=-1004415462717

# Optional: always allow these Telegram user IDs in DM (/start menu)
ADMIN_IDS=123456789

# Optional: /stocks cache in seconds (default 30)
# STOCK_CACHE_SECONDS=30

# Optional: override /stocks tickers (symbol:Label pairs, comma-separated)
# STOCK_WATCHLIST=AAPL:Apple,MSFT:Microsoft,AMZN:Amazon,META:Meta,QQQ:Nasdaq 100,SPY:S&P 500

# TELEGRAM_CHAT_ID=-1004415462717
# TELEGRAM_TOPIC_ID=4
